PORT=3000

# Local/manual connection (used if DATABASE_URL is not set)
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres

# If your host provides a single connection string (Render, Railway, Neon, Supabase...),
# set DATABASE_URL instead and it will take priority over the DB_* vars above.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_SSL=true
